PORT=3001
NODE_ENV=development

# ── Supabase ──────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # secret — never expose to frontend
SUPABASE_ANON_KEY=your-anon-key                   # safe to expose to frontend

# ── Retailer APIs ─────────────────────────────────────────────
SERP_API_KEY=

# ── AI ────────────────────────────────────────────────────────
OPENAI_API_KEY=
